{
  "manifest_version": 3,
  "name": "MoKao",
  "version": "2.3.0",
  "description": "粉笔模考爬虫 - 提取题目导出 Markdown，支持 Obsidian 直存。三级降级：服务器 → obsidian:// URI → 本地下载。",
  "permissions": [
    "downloads",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://spa.fenbi.com/*",
    "https://tiku.fenbi.com/*",
    "https://fenbi.com/*",
    "https://fb.fbstatic.cn/*",
    "http://localhost:8765/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://spa.fenbi.com/ti/exam/solution/*",
        "https://spa.fenbi.com/ti/exam/report/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "options_ui": {
    "page": "settings.html",
    "open_in_tab": false
  }
}